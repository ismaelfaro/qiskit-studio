## Maestro
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

## LLM endpoint (OpenAI-compatible).
# Default: local Ollama.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=dummy

# OpenRouter (free models via the `:free` slug, e.g. openai/gpt-oss-20b:free).
# Set these and pick a `:free` model in each agent's agents.yaml. Get a key at
# https://openrouter.ai/keys — do NOT commit it (the real value lives in .env).
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-...

## coderun-agent
# coderun-agent executes arbitrary Python. When set, /run requires this secret
# in the X-API-Key header. Strongly recommended for any non-localhost exposure.
# CODERUN_API_KEY=change-me