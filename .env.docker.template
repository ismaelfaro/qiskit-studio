# Copy to `.env` (gitignored) and fill in your key:  cp .env.docker.template .env
#
# LLM via OpenRouter (OpenAI-compatible). Used by chat-agent and codegen-agent.
# The agents pick free models in their agents.yaml (e.g. openai/gpt-oss-20b:free).
# Get a key at https://openrouter.ai/keys — do NOT commit the real value.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...
# LLM model for chat + codegen agents. Any OpenRouter slug; `:free` = no cost.
# e.g. openai/gpt-oss-120b:free, google/gemma-4-31b-it:free, z-ai/glm-4.5-air:free
LLM_MODEL=nex-agi/nex-n2-pro:free

# Embeddings for the RAG vector DB (knowledge-mcp). OpenRouter has NO embeddings
# endpoint, so this must point at a real embeddings provider. Default: host Ollama
# serving `nomic-embed-text` (run `ollama pull nomic-embed-text`).
CUSTOM_EMBEDDING_URL=http://host.docker.internal:11434/v1
CUSTOM_EMBEDDING_MODEL=nomic-embed-text
CUSTOM_EMBEDDING_VECTORSIZE=768
CUSTOM_EMBEDDING_API_KEY=dummy

# Optional overrides
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CODERUN_API_KEY=                 # set to require X-API-Key on /run
# FRONTEND_PORT=3000
# CHAT_PORT=8000
# CODEGEN_PORT=8001
# CODERUN_PORT=8002
